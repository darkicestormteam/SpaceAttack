[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_ai/plugin.cfg", "res://addons/virtual_joystick/plugin.cfg", "res://addons/yandex_games_sdk/plugin.cfg")

[gui]

theme/custom_font="res://assets/fonts/SonicPressStartButton[NolivantNTEdit]-Regular.ttf"
