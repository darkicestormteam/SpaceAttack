[application]

config/name="SpaceAttack"
run/main_scene="res://ui/screens/Hangar.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://c735u5yx75s5t"

[autoload]

SaveManager="*res://project_root/autoloads/SaveManager.gd"
Constant="*uid://cl7r5iw8qnhd3"
AudioManager="*res://project_root/autoloads/AudioManager.gd"
AutoWrap="*res://project_root/autoloads/AutoWrap.gd"
YandexSDK="*uid://d1bthq2mru8h7"
