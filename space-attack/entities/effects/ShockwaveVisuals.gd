extends Node2D

# Визуальная часть Shockwave. Рисует яркий круг с волновым контуром.
# Скрипт Shockwave.gd управляет scale родительского Area2D,
# но мы дублируем рисование в локальных координатах (радиус 1),
# чтобы масштабирование работало корректно.

func _ready() -> void:
	z_index = 10
	queue_redraw()


func _draw() -> void:
	# Внешний волновой контур
	draw_arc(Vector2.ZERO, 1.0, 0.0, TAU, 64, Color(0.4, 0.8, 1.0, 0.9), 0.04)
	# Внутренний волновой контур (чуть сдвинут, для эффекта)
	draw_arc(Vector2.ZERO, 0.92, 0.0, TAU, 48, Color(0.6, 0.9, 1.0, 0.6), 0.03)
	# Полупрозрачная заливка
	draw_circle(Vector2.ZERO, 0.98, Color(0.3, 0.7, 1.0, 0.18))
